# HelaPay PHP API — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# HelaPay credentials (from your HelaPay merchant portal)
HELA_APP_ID=your_app_id_here
HELA_APP_SECRET=your_app_secret_here
HELA_BASE_URL=https://api.helapay.lk
HELA_BUSINESS_ID=your_business_id_here

# Webhook HMAC secret (agree this with HelaPay support)
WEBHOOK_SECRET=your_webhook_secret_here

# Your own API key to protect these endpoints from unauthorised callers
# Generate with: php -r "echo bin2hex(random_bytes(32));"
API_KEY=your_api_key_here

# HTTP timeout for outbound requests (seconds)
HTTP_TIMEOUT_SEC=15

# Directory to cache tokens (must be writable by the web server, outside web root)
TOKEN_CACHE_DIR=/var/cache/helapay_tokens

# Allowed CORS origins (comma-separated, or * for dev)
ALLOWED_ORIGINS=https://yourdomain.com
